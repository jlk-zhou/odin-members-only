<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Join The Club</title>
</head>
<body>
  <h1>Join the Club as <%= user.firstname %> <%= user.lastname %></h1>
  <form action="/join-club" method="POST">
    <label for="club-password">Please enter the password to the club:</label>
    <br>
    <input type="password" name="club-password" id="club-password">
    <br>
    <button type="submit">Join</button>
  </form>
  <a href="/">Back to Home</a>
</body>
</html>